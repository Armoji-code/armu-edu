# Copy this file to backend/.env and fill in your values.
# python-dotenv loads it automatically when you run app.py.

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Database — defaults to SQLite at repo root. Use postgres:// for production.
# DATABASE_URL=postgresql://user:pass@localhost/mokyai

# Set to 1 for local development only — never in production
FLASK_DEBUG=0

# Allowed origins for CORS / WebSocket connections (comma-separated)
CORS_ORIGINS=http://localhost:5000

# ── AI provider ────────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic
# All of these can also be changed at runtime via Admin → Settings.
AI_PROVIDER=ollama

# Ollama (local inference — default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TUTOR_MODEL=gemma3:12b
OLLAMA_ADVANCED_MODEL=gemma3:12b
OLLAMA_TRACKER_MODEL=llama3.2:3b
